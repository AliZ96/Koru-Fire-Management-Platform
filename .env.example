# =============================================================================
# KORU — ortam değişkenleri
# Kopyalama:  cp .env.example .env
# .env ve secrets/*.json asla repoya commit edilmez.
# =============================================================================

# --- Uygulama (genelde yeter) ---
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# Virgülle ayrılmış izinli kökenler. Yerelde geniş kullanım için "*" da yazılabilir.
BACKEND_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# JWT (backend token üretimi için zorunlu). Üretimde mutlaka güçlü ve gizli bir değer kullanın.
SECRET_KEY=change-this-before-real-deployment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# Firebase / Firestore (backend Admin SDK — kullanıcı sync, FirestoreStore vb.)
# =============================================================================
# Firebase Console → Project settings → General → Project ID
FIREBASE_PROJECT_ID=koru-41307

# Service account JSON dosyasının tam yolu (her ortamda farklı olabilir).
# Örnek Windows: C:/Users/you/proj/secrets/koru-xxxxx-firebase-adminsdk-xxxxx.json
# Örnek macOS/Linux: /Users/you/proj/secrets/koru-xxxxx-firebase-adminsdk-xxxxx.json
FIREBASE_CREDENTIALS_PATH=

# Firebase Console → Project settings → General → Web API anahtarı (aynı web app apiKey).
# Sadece POST /auth/user/login içindeki Firebase e‑posta/şifre fallback için gerekli.
# Tarayıcıdaki login.html akışı için değil — o gömülü apiKey kullanır.
FIREBASE_WEB_API_KEY=

# =============================================================================
# PostgreSQL — İSTEĞE BAĞLI
# Uygulama çekirdeği Firestore kullanır. DATABASE_URL boş bırakılabilir.
# docker compose ile koşarken: önce aşağıdaki POSTGRES_* değerlerini doldurun,
# DATABASE_URL'te host adı "db" olmalı.
# =============================================================================
DATABASE_URL=

POSTGRES_USER=koru
POSTGRES_PASSWORD=koru123
POSTGRES_DB=koru_db
# docker-compose içi veritabanı servis adı; sadece container ağında "db"
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Yerel Postgres (docker yok): örnek
# DATABASE_URL=postgresql+psycopg2://koru:koru123@localhost:5432/koru_db

# =============================================================================
# Harici servisler — İSTEĞE BAĞLI
# =============================================================================
# NASA FIRMS yangın noktaları — https://firms.modaps.eosdis.nasa.gov/api/area/
MAP_KEY=

SOURCE=VIIRS_SNPP_NRT
IZMIR_BBOX=26.0,37.5,28.5,39.5

OPEN_METEO_BASE=https://api.open-meteo.com/v1/forecast
TZ=Europe/Istanbul

# Örn. ayrı geo mikroservisi varsa
GEO_SERVICE_BASE_URL=

# =============================================================================
# İnce ayar (varsayılanlar kodda; .env'de override edilebilir)
# =============================================================================
# FIRMS_CACHE_TTL_SECONDS=120
# WEATHER_CACHE_TTL=300
# WEATHER_TIMEOUT=6
# ROUTING_MAX_LOW_NODES=1200
